<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CalculadoraInteligente.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MultiC&#x00E1;lculos"
        Height="590"
        Width="415"
        MinHeight="590"
        MinWidth="415"
        MaxHeight="590"
        MaxWidth="415"
        FontFamily="Tahoma"
        KeyDown="Window_KeyDown"
        WindowStartupLocation="CenterScreen"
        Background="#D4D0C8"
        ResizeMode="CanMinimize">

    <Window.Resources>

        <!-- ===== WINDOWS XP CLASSIC PALETTE ===== -->
        <SolidColorBrush x:Key="XpFace"       Color="#D4D0C8" />
        <SolidColorBrush x:Key="XpHighlight"  Color="#FFFFFF" />
        <SolidColorBrush x:Key="XpShadow"     Color="#808080" />
        <SolidColorBrush x:Key="XpDkShadow"   Color="#404040" />
        <SolidColorBrush x:Key="XpBlue"       Color="#0054E3" />
        <SolidColorBrush x:Key="XpDisplay"    Color="#FFFFFF" />
        <SolidColorBrush x:Key="Accent"        Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#003070" />

        <!-- ===== MENU STYLE ===== -->
        <Style TargetType="{x:Type Menu}">
            <Setter Property="Background"  Value="#D4D0C8"/>
            <Setter Property="Foreground"  Value="#000000"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontFamily"  Value="Tahoma"/>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground"  Value="#000000"/>
            <Setter Property="Background"  Value="#D4D0C8"/>
            <Setter Property="Padding"     Value="6,3"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontFamily"  Value="Tahoma"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition SharedSizeGroup="IconGroup" Width="18"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="IGTGroup"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <ContentPresenter x:Name="IconHost" ContentSource="Icon"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Path x:Name="CheckMark"
                                              Stroke="#0054E3" StrokeThickness="2"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"
                                              Visibility="Collapsed"
                                              Data="M 1 5 L 4 8 L 9 1"/>
                                    </Grid>
                                    <ContentPresenter x:Name="HeaderHost" Grid.Column="2"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" x:Name="IGT"
                                               Text="{TemplateBinding InputGestureText}"
                                               Margin="16,0,4,0" Foreground="#808080"
                                               VerticalAlignment="Center"/>
                                    <Path Grid.Column="4" x:Name="Arrow"
                                          Fill="#404040" VerticalAlignment="Center"
                                          HorizontalAlignment="Right" Visibility="Collapsed"
                                          Data="M 0 0 L 4 4 L 0 8 Z"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="None" Placement="Bottom">
                                <Border Background="#D4D0C8" BorderBrush="#808080"
                                        BorderThickness="1" Padding="1,2" SnapsToDevicePixels="True">
                                    <ItemsPresenter Grid.IsSharedSizeScope="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    KeyboardNavigation.TabNavigation="Cycle"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IGT"      Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Arrow"    Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IGT"      Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Arrow"    Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow"      Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_Popup" Property="Placement"  Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0054E3"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#808080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Background="#808080" Margin="4,2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== XP 3-D RAISED BUTTON ===== -->
        <!-- Outer: #404040  |  Highlight: #FFF (top-left)  |  Shadow: #808080 (btm-right) -->
        <Style x:Key="CalcButtonStyle" TargetType="Button">
            <Setter Property="Margin"          Value="2"/>
            <Setter Property="Padding"         Value="2"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="Background"      Value="#D4D0C8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 1. Outer dark frame -->
                        <Border x:Name="Outer"
                                BorderThickness="1" BorderBrush="#404040"
                                SnapsToDevicePixels="True">
                            <!-- 2. White highlight top-left -->
                            <Border x:Name="Hi"
                                    BorderThickness="2,2,1,1"
                                    BorderBrush="#FFFFFF">
                                <!-- 3. Gray shadow bottom-right -->
                                <Border x:Name="Sh"
                                        BorderThickness="1,1,2,2"
                                        BorderBrush="#808080"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Sh" Property="Background" Value="#E8E4DC"/>
                            </Trigger>
                            <!-- Pressed: invert bevel = depressed look -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Hi" Property="BorderBrush" Value="#808080"/>
                                <Setter TargetName="Sh" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter TargetName="Sh" Property="Background"  Value="#C0BDB5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sunken/inset panel border (for display & history) -->
        <Style x:Key="SunkenPanel" TargetType="Border">
            <Setter Property="BorderThickness" Value="2,2,1,1"/>
            <Setter Property="BorderBrush"     Value="#808080"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

    </Window.Resources>

    <!-- ============================================================
         ROOT: flat XP gray, thin outer ridge
    ============================================================ -->
    <Border Background="#D4D0C8"
            BorderThickness="2,2,1,1" BorderBrush="#FFFFFF"
            SnapsToDevicePixels="True">
        <Border BorderThickness="1,1,2,2" BorderBrush="#808080">

            <DockPanel Margin="4">

                <!-- â”€â”€ MENU BAR â”€â”€ -->
                <Menu DockPanel.Dock="Top"
                      Background="#D4D0C8" Foreground="#000000"
                      Padding="0">
                    <MenuItem Header="_Opções">
                        <MenuItem Header="Abrir Outra Inst?ncia" InputGestureText="F6"  Click="OpenAnotherCalculator_Click"/>
                        <Separator/>
                        <MenuItem Header="Calcular Data"           Click="CalculoData_Click"/>
                        <MenuItem Header="Conversor de Medidas"    Click="ConversorMedidas_Click"/>
                        <MenuItem Header="Calcular Tempo"          Click="CalculoTempo_Click"/>
                        <MenuItem Header="Aumento / Redução"      Click="AumentoReducao_Click"/>
                        <MenuItem Header="Juros Capitalizados"     Click="JurosCapitalizados_Click"/>
                        <MenuItem Header="Regra de Tres"           Click="RegrasDeTres_Click"/>
                        <MenuItem Header="Peso Ideal / IMC"        Click="CalculoIMC_Click"/>
                        <Separator/>
                        <MenuItem Header="Limpar Histórico"        Click="ClearHistory_Click"/>
                        <MenuItem Header="Sair"                    Click="Exit_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Configurações">
                        <MenuItem Header="Sempre Visível (On Top)" IsCheckable="True"
                                  Checked="AlwaysOnTop_Checked" Unchecked="AlwaysOnTop_Checked"/>
                        <MenuItem Header="Som ao Digitar" IsCheckable="True" IsChecked="True"
                                  Checked="BeepOnType_Checked" Unchecked="BeepOnType_Checked"/>
                    </MenuItem>
                    <MenuItem Header="_?">
                        <MenuItem Header="Ajuda"                        InputGestureText="F1"  Click="Help_Click"/>
                        <MenuItem Header="Sobre a Calculadora"          InputGestureText="F11" Click="About_Click"/>
                        <MenuItem Header="Registro (Licença de Uso)"    InputGestureText="F12" Click="License_Click"/>
                        <Separator/>
                        <MenuItem Header="Enviar e-mail ao suporte"     Click="SupportEmail_Click"/>
                    </MenuItem>
                </Menu>

                <!-- â”€â”€ STATUS BAR â”€â”€ -->
                <StatusBar DockPanel.Dock="Bottom"
                           Background="#D4D0C8" Foreground="#000000"
                           BorderThickness="1,1,0,0" BorderBrush="#808080"
                           Margin="0,3,0,0" Padding="3,1">
                    <StatusBarItem>
                        <TextBlock Name="StatusText" Text="Pronto" FontSize="11" FontFamily="Tahoma"/>
                    </StatusBarItem>
                </StatusBar>

                <!-- â”€â”€ MAIN CONTENT â”€â”€ -->
                <Grid Margin="2,3,2,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- XP title strip -->
                        <RowDefinition Height="95"/>     <!-- history         -->
                        <RowDefinition Height="62"/>     <!-- MEM + display   -->
                        <RowDefinition Height="*"/>      <!-- button pad      -->
                    </Grid.RowDefinitions>

                    <!-- â”€â”€ XP TITLE STRIP â”€â”€ -->
                    <Border x:Name="HeaderBorder" Grid.Row="0" Margin="0,0,0,4"
                            BorderThickness="1" BorderBrush="#003070"
                            SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,0,0" BorderBrush="#6898D0">
                            <Border BorderThickness="0,0,1,1" BorderBrush="#003070">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0A246A" Offset="0"/>
                                        <GradientStop Color="#3A6EA5" Offset="0.5"/>
                                        <GradientStop Color="#0A246A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Margin="5,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="HeaderTitle"
                                               Text="MULTIC&#x00C1;LCULOS"
                                               Foreground="#FFFFFF" FontSize="12"
                                               FontWeight="Bold" FontFamily="Tahoma"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="by Cristiano Pirolli"
                                               Foreground="#A8C8F0" FontSize="10"
                                               FontFamily="Tahoma" FontStyle="Italic"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Border>
                    </Border>

                    <!-- â”€â”€ HISTORY (sunken inset) â”€â”€ -->
                    <Border Grid.Row="1" Margin="0,0,0,4"
                            BorderThickness="2,2,1,1" BorderBrush="#808080"
                            SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF"
                                Background="#FFFFFF">
                            <ScrollViewer x:Name="HistoryScrollViewer"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBox Name="HistoryTextBox"
                                         Background="Transparent"
                                         Foreground="#000080"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         FontFamily="Courier New"
                                         FontSize="12"
                                         Padding="3"/>
                            </ScrollViewer>
                        </Border>
                    </Border>

                    <!-- â”€â”€ MEMORY + DISPLAY â”€â”€ -->
                    <Grid Grid.Row="2" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- MEM panel -->
                        <Border Grid.Column="0"
                                BorderThickness="2,2,1,1" BorderBrush="#808080"
                                SnapsToDevicePixels="True">
                            <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF"
                                    Background="#C8C4BC">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="MEM" Foreground="#404040"
                                               FontSize="8" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                    <TextBlock Name="MemoryIndicator" Text="000"
                                               FontSize="17" FontWeight="Bold"
                                               FontFamily="Courier New"
                                               Foreground="#000080"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Display panel -->
                        <Border Grid.Column="1"
                                BorderThickness="2,2,1,1" BorderBrush="#808080"
                                SnapsToDevicePixels="True">
                            <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF"
                                    Background="#FFFFFF">
                                <TextBox Name="DisplayTextBox"
                                         Text="0"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#000000"
                                         FontFamily="Courier New"
                                         FontSize="30"
                                         FontWeight="Bold"
                                         TextAlignment="Right"
                                         VerticalContentAlignment="Center"
                                         Padding="5,0"/>
                            </Border>
                        </Border>
                    </Grid>

                    <!-- â”€â”€ BUTTON PAD â”€â”€ -->
                    <!-- Outer raised panel wrapping all buttons -->
                    <Border Grid.Row="3"
                            BorderThickness="2,2,1,1" BorderBrush="#FFFFFF"
                            SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,2,2" BorderBrush="#808080"
                                Background="#D4D0C8" Padding="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- â”€â”€ MEMORY column (maroon on blush) â”€â”€ -->
                                <Button Grid.Row="0" Grid.Column="0" Content="MC" Tag="MC"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#C8B4B8" Foreground="#800000"
                                        ToolTip="Limpar mem&#243;ria (Memory Clear)"/>
                                <Button Grid.Row="1" Grid.Column="0" Content="MR" Tag="MR"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#C8B4B8" Foreground="#800000"
                                        ToolTip="Recuperar mem&#243;ria (Memory Recall)"/>
                                <Button Grid.Row="2" Grid.Column="0" Content="M-" Tag="M-"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#C8B4B8" Foreground="#800000"
                                        ToolTip="Subtrair da mem&#243;ria (Memory Subtract)"/>
                                <Button Grid.Row="3" Grid.Column="0" Content="M+" Tag="M+"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#C8B4B8" Foreground="#800000"
                                        ToolTip="Adicionar &#224; mem&#243;ria (Memory Add)"/>

                                <!-- ROW 0: 7 8 9 ÷ ← -->
                                <Button Grid.Row="0" Grid.Column="1" Content="7" Tag="7"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="8" Tag="8"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="0" Grid.Column="3" Content="9" Tag="9"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="0" Grid.Column="4" Content="&#247;" Tag="/"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#B8C8DC" Foreground="#000080"/>
                                <Button Grid.Row="0" Grid.Column="5" Content="&#8592;" Tag="Back"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#C8C4B8" Foreground="#404040"/>

                                <!-- ROW 1: 4 5 6 × CE -->
                                <Button Grid.Row="1" Grid.Column="1" Content="4" Tag="4"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="5" Tag="5"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="1" Grid.Column="3" Content="6" Tag="6"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="1" Grid.Column="4" Content="&#215;" Tag="*"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#B8C8DC" Foreground="#000080"/>
                                <Button Grid.Row="1" Grid.Column="5" Content="CE" Tag="CE"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#D0B8B8" Foreground="#800000"/>

                                <!-- â”€â”€ ROW 2: 1 2 3 - % â”€â”€ -->
                                <Button Grid.Row="2" Grid.Column="1" Content="1" Tag="1"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="2" Tag="2"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="2" Grid.Column="3" Content="3" Tag="3"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="2" Grid.Column="4" Content="-" Tag="-"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#B8C8DC" Foreground="#000080"/>
                                <Button Grid.Row="2" Grid.Column="5" Content="%" Tag="%"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#C8C4B8" Foreground="#404040"/>

                                <!-- â”€â”€ ROW 3: 0 +/- , + = â”€â”€ -->
                                <Button Grid.Row="3" Grid.Column="1" Content="0" Tag="0"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="3" Grid.Column="2" Content="+/-" Tag="Sign"
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"
                                        FontSize="12"/>
                                <Button Grid.Row="3" Grid.Column="3" Content="," Tag=","
                                        Click="CommandButton_Click" Style="{StaticResource CalcButtonStyle}"/>
                                <Button Grid.Row="3" Grid.Column="4" Content="+" Tag="+"
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#B8C8DC" Foreground="#000080"/>
                                <!-- = : XP blue solid, inverted text -->
                                <Button Grid.Row="3" Grid.Column="5" Content="=" Tag="="
                                        Click="CommandButton_Click"
                                        Style="{StaticResource CalcButtonStyle}"
                                        Background="#0054E3" Foreground="#FFFFFF"
                                        FontSize="18"/>
                            </Grid>
                        </Border>
                    </Border>

                </Grid>
            </DockPanel>

        </Border>
    </Border>
</Window>





