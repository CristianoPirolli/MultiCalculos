<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CalculadoraInteligente.UI.Tools.AumentoReducao"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajuste de Valor"
        Height="560" Width="430"
        MinHeight="560" MinWidth="430"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Tahoma"
        Background="#D4D0C8">

    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldInputStyle" TargetType="TextBox" BasedOn="{StaticResource ToolInputStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="FieldComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Tahoma"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#808080"/>
            <Setter Property="BorderThickness" Value="2,2,1,1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <Style x:Key="FieldOutputStyle" TargetType="TextBox" BasedOn="{StaticResource ToolInputStyle}">
            <Setter Property="Background" Value="#E8E4DC"/>
            <Setter Property="Foreground" Value="#000080"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Border Background="#D4D0C8" BorderThickness="2,2,1,1" BorderBrush="#FFFFFF" SnapsToDevicePixels="True">
        <Border BorderThickness="1,1,2,2" BorderBrush="#808080">
            <StackPanel Margin="14">
                <Border BorderThickness="1" BorderBrush="#003070" Margin="0,0,0,12" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,0,0" BorderBrush="#6898D0">
                        <Border BorderThickness="0,0,1,1" BorderBrush="#003070">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0A246A" Offset="0"/>
                                    <GradientStop Color="#3A6EA5" Offset="0.5"/>
                                    <GradientStop Color="#0A246A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="AJUSTE DE VALOR"
                                       Foreground="#FFFFFF"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Padding="8,5"/>
                        </Border>
                    </Border>
                </Border>

                <Border BorderThickness="2,2,1,1" BorderBrush="#808080" Margin="0,0,0,12" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#D4D0C8" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Valor base (100%)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Grid.Row="1" x:Name="TbValorInicial" Style="{StaticResource FieldInputStyle}" Text="50000,00" TextChanged="Entrada_TextChanged"/>

                            <TextBlock Grid.Row="2" Text="Tipo de ajuste" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4"/>
                            <ComboBox Grid.Row="3" x:Name="CbOperacao" Style="{StaticResource FieldComboStyle}" SelectionChanged="SelectionChanged_Recalcular">
                                <ComboBoxItem Content="Aumentar" IsSelected="True"/>
                                <ComboBoxItem Content="Reduzir"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Text="Digite em" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4"/>
                            <Grid Grid.Row="5" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" x:Name="CbModoEntrada" Style="{StaticResource FieldComboStyle}" SelectionChanged="SelectionChanged_Recalcular">
                                    <ComboBoxItem Content="Porcentagem" IsSelected="True"/>
                                    <ComboBoxItem Content="Valor"/>
                                </ComboBox>
                                <TextBox Grid.Column="2" x:Name="TbEntrada" Style="{StaticResource FieldInputStyle}" Text="30" TextChanged="Entrada_TextChanged"/>
                            </Grid>

                            <TextBlock Grid.Row="6" x:Name="LblEntradaCalculada" Text="Valor do ajuste" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Grid.Row="7" x:Name="TbEntradaCalculada" Style="{StaticResource FieldOutputStyle}"/>

                            <TextBlock Grid.Row="8" x:Name="LblResultadoFinal" Text="Valor final" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4"/>
                            <TextBox Grid.Row="9" x:Name="TbResultadoFinal" Style="{StaticResource FieldOutputStyle}"/>
                        </Grid>
                    </Border>
                </Border>

                <Border BorderThickness="2,2,1,1" BorderBrush="#808080" Margin="0,0,0,12" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#FFFFFF" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Resultado" Foreground="#000080" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" x:Name="TxtResumoPercentual" Style="{StaticResource ToolResultValueStyle}" Text="Percentual: -"/>
                            <TextBlock Grid.Row="2" x:Name="TxtResumoValor" Style="{StaticResource ToolResultValueStyle}" Text="Valor do ajuste: -"/>
                            <TextBlock Grid.Row="3" x:Name="TxtResumoResultado" Style="{StaticResource ToolResultValueStyle}" Text="Valor final: -"/>
                        </Grid>
                    </Border>
                </Border>

                <Button Content="Calcular" Style="{StaticResource ToolButtonStyle}" Height="40" Click="Calcular_Click"/>
            </StackPanel>
        </Border>
    </Border>
</Window>
