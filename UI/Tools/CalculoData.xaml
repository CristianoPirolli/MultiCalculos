<Window x:Class="CalculadoraInteligente.UI.Tools.CalculoData"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calcular Data"
        Height="460" Width="780"
        MinHeight="460" MinWidth="780"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Tahoma"
        Background="#D4D0C8">
    <Window.Resources>

        <!-- Botão dos dias do calendário -->
        <Style x:Key="DayBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Tahoma"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B8C8DC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#8098C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de unidade -->
        <Style x:Key="UnitBtnStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Height"   Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding"  Value="8,2"/>
        </Style>

        <!-- Input de unidade (somente leitura) -->
        <Style x:Key="UnitInputStyle" TargetType="TextBox" BasedOn="{StaticResource ToolInputStyle}">
            <Setter Property="Height"          Value="26"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="TextAlignment"   Value="Center"/>
            <Setter Property="Background"      Value="#E8E4DC"/>
            <Setter Property="Foreground"      Value="#000080"/>
            <Setter Property="IsReadOnly"      Value="True"/>
        </Style>

    </Window.Resources>

    <!-- XP outer ridge -->
    <Border Background="#D4D0C8" BorderThickness="2,2,1,1" BorderBrush="#FFFFFF" SnapsToDevicePixels="True">
        <Border BorderThickness="1,1,2,2" BorderBrush="#808080">

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ PAINEL ESQUERDO ═══ -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Banner Hoje -->
                    <Border Grid.Row="0" Margin="0,0,0,8"
                            BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#D4D0C8"
                                Padding="8,6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TbHoje1" Foreground="#000080" FontSize="14"
                                           FontWeight="Bold" TextAlignment="Center"/>
                                <TextBlock x:Name="TbHoje2" Foreground="#404040" FontSize="11"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Data Inicial -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,6">
                        <TextBlock Text="Data Inicial" Foreground="#000000" FontSize="12"
                                   FontWeight="Bold" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TbDataInicial" Grid.Column="0"
                                     Style="{StaticResource ToolInputStyle}"
                                     Height="30" FontSize="13"
                                     GotFocus="DataInicial_GotFocus"
                                     TextChanged="DataInicial_TextChanged"/>
                            <TextBox x:Name="TbDiaSemanInicial" Grid.Column="2"
                                     Style="{StaticResource ToolInputStyle}"
                                     Height="30" FontSize="12" IsReadOnly="True"
                                     Background="#E8E4DC" Foreground="#404040"/>
                        </Grid>
                    </StackPanel>

                    <!-- Botão Calcular Data Final -->
                    <Button Grid.Row="2" x:Name="BtnCalcFinal" Content="Calcular Data Final"
                            Style="{StaticResource ToolButtonStyle}"
                            HorizontalAlignment="Stretch" FontSize="12" Padding="8,5"
                            Margin="0,0,0,6" Click="CalcularDataFinal_Click"/>

                    <!-- Data Final -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <TextBlock Text="Data Final" Foreground="#000000" FontSize="12"
                                   FontWeight="Bold" Margin="0,0,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TbDataFinal" Grid.Column="0"
                                     Style="{StaticResource ToolInputStyle}"
                                     Height="30" FontSize="13"
                                     GotFocus="DataFinal_GotFocus"
                                     TextChanged="DataFinal_TextChanged"/>
                            <TextBox x:Name="TbDiaSemanFinal" Grid.Column="2"
                                     Style="{StaticResource ToolInputStyle}"
                                     Height="30" FontSize="12" IsReadOnly="True"
                                     Background="#E8E4DC" Foreground="#404040"/>
                        </Grid>
                    </StackPanel>

                    <!-- Separador -->
                    <Border Grid.Row="4" Background="#808080" Height="1" Margin="0,0,0,8"/>

                    <!-- Unidades: Anos / Meses / Semanas / Dias -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0" x:Name="TbAnos"   Style="{StaticResource UnitInputStyle}"/>
                        <Button  Grid.Row="0" Grid.Column="2" Content="Anos"    Style="{StaticResource UnitBtnStyle}" Click="BtnAnos_Click"/>

                        <TextBox Grid.Row="0" Grid.Column="4" x:Name="TbDias"   Style="{StaticResource UnitInputStyle}"/>
                        <Button  Grid.Row="0" Grid.Column="6" Content="Dias"    Style="{StaticResource UnitBtnStyle}" Click="BtnDias_Click"/>

                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="TbMeses"  Style="{StaticResource UnitInputStyle}"/>
                        <Button  Grid.Row="1" Grid.Column="2" Content="Meses"   Style="{StaticResource UnitBtnStyle}" Click="BtnMeses_Click"/>

                        <TextBox Grid.Row="2" Grid.Column="0" x:Name="TbSemanas" Style="{StaticResource UnitInputStyle}"/>
                        <Button  Grid.Row="2" Grid.Column="2" Content="Semanas" Style="{StaticResource UnitBtnStyle}" Click="BtnSemanas_Click"/>
                    </Grid>
                </Grid>

                <!-- ═══ PAINEL DIREITO: CALENDÁRIO ═══ -->
                <Border Grid.Column="2"
                        BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#D4D0C8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="26"/>
                            </Grid.RowDefinitions>

                            <!-- Navegação mês/ano -->
                            <Grid Grid.Row="0" Background="#D4D0C8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="◄" Foreground="#000080"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="13" Cursor="Hand" Click="PrevMonth_Click"/>
                                <TextBlock x:Name="TbMesAno" Grid.Column="1"
                                           Foreground="#000080" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="►" Foreground="#000080"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="13" Cursor="Hand" Click="NextMonth_Click"/>
                            </Grid>

                            <!-- Cabeçalho dias da semana -->
                            <UniformGrid Grid.Row="1" Rows="1" Columns="7" Background="#D4D0C8">
                                <TextBlock Text="dom" Foreground="#800000" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="seg" Foreground="#000080" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="ter" Foreground="#000080" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="qua" Foreground="#000080" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="qui" Foreground="#000080" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="sex" Foreground="#000080" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="sáb" Foreground="#800000" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </UniformGrid>

                            <!-- Grade dos dias -->
                            <UniformGrid x:Name="DaysGrid" Grid.Row="2" Rows="6" Columns="7"
                                         Background="#FFFFFF"/>

                            <!-- Rodapé: hoje -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="#D4D0C8">
                                <Ellipse Width="14" Height="14" Stroke="#EF4444" StrokeThickness="2"
                                         Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TbTodayFooter" Foreground="#000000"
                                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
