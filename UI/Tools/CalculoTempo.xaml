<Window x:Class="CalculadoraInteligente.UI.Tools.CalculoTempo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculadora de Tempo"
        Height="720" Width="480"
        MinHeight="680" MinWidth="460"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Tahoma"
        Background="#D4D0C8"
        KeyDown="Window_KeyDown">
    <Window.Resources>

        <!-- XP 3-D raised button — identical look to main calculator -->
        <Style x:Key="TCalcBtn" TargetType="Button">
            <Setter Property="Margin"          Value="2"/>
            <Setter Property="Padding"         Value="2"/>
            <Setter Property="FontSize"        Value="18"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="Background"      Value="#D4D0C8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="60"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Outer" BorderThickness="1" BorderBrush="#404040" SnapsToDevicePixels="True">
                            <Border x:Name="Hi" BorderThickness="2,2,1,1" BorderBrush="#FFFFFF">
                                <Border x:Name="Sh" BorderThickness="1,1,2,2" BorderBrush="#808080"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Sh" Property="Background" Value="#E8E4DC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Hi" Property="BorderBrush" Value="#808080"/>
                                <Setter TargetName="Sh" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter TargetName="Sh" Property="Background"  Value="#C0BDB5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- XP outer ridge -->
    <Border Background="#D4D0C8" BorderThickness="2,2,1,1" BorderBrush="#FFFFFF" SnapsToDevicePixels="True">
        <Border BorderThickness="1,1,2,2" BorderBrush="#808080">

            <DockPanel Margin="6">

                <!-- ── HISTÓRICO ── -->
                <Border DockPanel.Dock="Top" Margin="0,0,0,6"
                        BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#FFFFFF">
                        <ScrollViewer x:Name="HistScroll" VerticalScrollBarVisibility="Auto" Height="200">
                            <TextBox x:Name="HistBox"
                                     Background="Transparent"
                                     Foreground="#000080"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Courier New"
                                     FontSize="13"
                                     Padding="4"/>
                        </ScrollViewer>
                    </Border>
                </Border>

                <!-- ── MEMÓRIA + DISPLAY ── -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6" Height="68">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#C8C4BC">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="MEM" Foreground="#404040" FontSize="8" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                <TextBlock x:Name="MemDisplay"
                                           Text="000" FontSize="20" FontWeight="Bold"
                                           FontFamily="Courier New" Foreground="#000080"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <Border Grid.Column="1"
                            BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#FFFFFF">
                            <TextBlock x:Name="TimeDisplay"
                                       Text="00:00:00"
                                       FontFamily="Courier New" FontSize="32" FontWeight="Bold"
                                       Foreground="#000000"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Padding="8,0"/>
                        </Border>
                    </Border>
                </Grid>

                <!-- ── GRADE DE BOTÕES ── -->
                <Border DockPanel.Dock="Top"
                        BorderThickness="2,2,1,1" BorderBrush="#FFFFFF" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,2,2" BorderBrush="#808080"
                            Background="#D4D0C8" Padding="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Memória (marrom) -->
                            <Button Grid.Row="0" Grid.Column="0" Content="MC" Tag="MC" Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#C8B4B8" Foreground="#800000"
                                    ToolTip="Limpar memória"/>
                            <Button Grid.Row="1" Grid.Column="0" Content="MR" Tag="MR" Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#C8B4B8" Foreground="#800000"
                                    ToolTip="Recuperar memória"/>
                            <Button Grid.Row="2" Grid.Column="0" Content="M-" Tag="M-" Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#C8B4B8" Foreground="#800000"
                                    ToolTip="Subtrair da memória"/>
                            <Button Grid.Row="3" Grid.Column="0" Content="M+" Tag="M+" Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#C8B4B8" Foreground="#800000"
                                    ToolTip="Adicionar à memória"/>

                            <!-- Linha 0: 7 8 9 ÷ ← -->
                            <Button Grid.Row="0" Grid.Column="1" Content="7"  Tag="7"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="8"  Tag="8"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="0" Grid.Column="3" Content="9"  Tag="9"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="0" Grid.Column="4" Content="&#247;" Tag="/" Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#B8C8DC" Foreground="#000080"/>
                            <Button Grid.Row="0" Grid.Column="5" Content="&#8592;" Tag="Back" Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#C8C4B8" Foreground="#404040"/>

                            <!-- Linha 1: 4 5 6 × CE -->
                            <Button Grid.Row="1" Grid.Column="1" Content="4"  Tag="4"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="5"  Tag="5"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="1" Grid.Column="3" Content="6"  Tag="6"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="1" Grid.Column="4" Content="&#215;" Tag="*" Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#B8C8DC" Foreground="#000080"/>
                            <Button Grid.Row="1" Grid.Column="5" Content="CE" Tag="CE"   Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#D0B8B8" Foreground="#800000"/>

                            <!-- Linha 2: 1 2 3 - % -->
                            <Button Grid.Row="2" Grid.Column="1" Content="1"  Tag="1"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="2"  Tag="2"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="2" Grid.Column="3" Content="3"  Tag="3"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="2" Grid.Column="4" Content="-"  Tag="-"    Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#B8C8DC" Foreground="#000080"/>
                            <Button Grid.Row="2" Grid.Column="5" Content="%"  Tag="%"    Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#C8C4B8" Foreground="#404040"/>

                            <!-- Linha 3: 0 00 C + = -->
                            <Button Grid.Row="3" Grid.Column="1" Content="0"  Tag="0"    Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="3" Grid.Column="2" Content="00" Tag="00"   Click="Btn_Click" Style="{StaticResource TCalcBtn}"/>
                            <Button Grid.Row="3" Grid.Column="3" Content="C"  Tag="C"    Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#C8C4B8" Foreground="#404040"/>
                            <Button Grid.Row="3" Grid.Column="4" Content="+"  Tag="+"    Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#B8C8DC" Foreground="#000080"/>
                            <Button Grid.Row="3" Grid.Column="5" Content="="  Tag="="    Click="Btn_Click"
                                    Style="{StaticResource TCalcBtn}" Background="#0054E3" Foreground="#FFFFFF" FontSize="22"/>
                        </Grid>
                    </Border>
                </Border>

            </DockPanel>
        </Border>
    </Border>
</Window>
