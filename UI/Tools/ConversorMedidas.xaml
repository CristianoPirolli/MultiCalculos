<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CalculadoraInteligente.UI.Tools.ConversorMedidas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conversor de Medidas"
        Height="480" Width="460"
        MinHeight="480" MinWidth="460"
        MaxHeight="480" MaxWidth="460"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Tahoma"
        Background="#D4D0C8">

    <!-- XP outer ridge -->
    <Border Background="#D4D0C8" BorderThickness="2,2,1,1" BorderBrush="#FFFFFF" SnapsToDevicePixels="True">
        <Border BorderThickness="1,1,2,2" BorderBrush="#808080">

            <DockPanel Margin="8">

                <!-- ── XP TITLE STRIP ── -->
                <Border DockPanel.Dock="Top" Margin="0,0,0,8"
                        BorderThickness="1" BorderBrush="#003070" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,0,0" BorderBrush="#6898D0">
                        <Border BorderThickness="0,0,1,1" BorderBrush="#003070" Padding="6,4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0A246A" Offset="0"/>
                                    <GradientStop Color="#3A6EA5" Offset="0.5"/>
                                    <GradientStop Color="#0A246A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="CONVERSOR DE MEDIDAS"
                                       Foreground="#FFFFFF" FontSize="12"
                                       FontWeight="Bold" FontFamily="Tahoma"/>
                        </Border>
                    </Border>
                </Border>

                <!-- ── HISTÓRICO ── -->
                <Border DockPanel.Dock="Bottom" Margin="0,8,0,0"
                        BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#FFFFFF">
                        <ScrollViewer x:Name="HistScroll" VerticalScrollBarVisibility="Auto" Height="90">
                            <TextBox x:Name="HistBox"
                                     Background="Transparent" Foreground="#000080"
                                     BorderThickness="0" IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Courier New" FontSize="12"
                                     Padding="4"/>
                        </ScrollViewer>
                    </Border>
                </Border>

                <!-- ── CONTEÚDO CENTRAL ── -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Categoria -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Categoria:" Foreground="#000000" FontSize="12"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CbCategoria" Grid.Column="1"
                                  FontFamily="Tahoma" FontSize="12"
                                  SelectionChanged="CbCategoria_SelectionChanged">
                            <ComboBoxItem Content="Comprimento"   Tag="comprimento" IsSelected="True"/>
                            <ComboBoxItem Content="Peso / Massa"  Tag="peso"/>
                            <ComboBoxItem Content="Temperatura"   Tag="temperatura"/>
                            <ComboBoxItem Content="&#193;rea"     Tag="area"/>
                            <ComboBoxItem Content="Volume"        Tag="volume"/>
                            <ComboBoxItem Content="Velocidade"    Tag="velocidade"/>
                            <ComboBoxItem Content="Press&#227;o"  Tag="pressao"/>
                        </ComboBox>
                    </Grid>

                    <!-- Painel DE (sunken) -->
                    <Border Grid.Row="2"
                            BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#FFFFFF" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="De:" Foreground="#000080" FontSize="12"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF">
                                        <TextBox x:Name="TbValorDe"
                                                 Text="1"
                                                 Background="#FFFFFF" Foreground="#000000"
                                                 BorderThickness="0"
                                                 FontFamily="Courier New" FontSize="20" FontWeight="Bold"
                                                 TextAlignment="Right"
                                                 VerticalContentAlignment="Center"
                                                 Padding="4,2"
                                                 TextChanged="TbValorDe_TextChanged"/>
                                    </Border>
                                </Border>
                                <ComboBox x:Name="CbUnidadeDe" Grid.Column="3"
                                          Height="34" FontFamily="Tahoma" FontSize="11"
                                          SelectionChanged="Unidade_SelectionChanged"/>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Seta -->
                    <TextBlock Grid.Row="3"
                               Text="&#x21D3;  ="
                               Foreground="#000080" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,4"/>

                    <!-- Painel PARA (sunken readonly) -->
                    <Border Grid.Row="4"
                            BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                        <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#E8E4DC" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Para:" Foreground="#800000" FontSize="12"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        BorderThickness="2,2,1,1" BorderBrush="#808080" SnapsToDevicePixels="True">
                                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF">
                                        <TextBox x:Name="TbResultado"
                                                 IsReadOnly="True"
                                                 Background="#F8F4EC" Foreground="#000000"
                                                 BorderThickness="0"
                                                 FontFamily="Courier New" FontSize="20" FontWeight="Bold"
                                                 TextAlignment="Right"
                                                 VerticalContentAlignment="Center"
                                                 Padding="4,2"/>
                                    </Border>
                                </Border>
                                <ComboBox x:Name="CbUnidadePara" Grid.Column="3"
                                          Height="34" FontFamily="Tahoma" FontSize="11"
                                          SelectionChanged="Unidade_SelectionChanged"/>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Botão Converter -->
                    <Button Grid.Row="6"
                            x:Name="BtnConverter"
                            Content="Converter"
                            Style="{StaticResource ToolButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="34" FontSize="13"
                            Click="BtnConverter_Click"/>

                </Grid>

            </DockPanel>
        </Border>
    </Border>
</Window>
