<Window x:Class="CalculadoraInteligente.UI.Tools.RegrasDeTres"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Regra de Três"
        Height="430" Width="420"
        MinHeight="430" MinWidth="420"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Tahoma"
        Background="#D4D0C8">

    <!-- XP outer ridge -->
    <Border Background="#D4D0C8" BorderThickness="2,2,1,1" BorderBrush="#FFFFFF" SnapsToDevicePixels="True">
        <Border BorderThickness="1,1,2,2" BorderBrush="#808080">

            <StackPanel Margin="14">

                <!-- Título -->
                <Border BorderThickness="1" BorderBrush="#003070" Margin="0,0,0,12"
                        SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,0,0" BorderBrush="#6898D0">
                        <Border BorderThickness="0,0,1,1" BorderBrush="#003070">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0A246A" Offset="0"/>
                                    <GradientStop Color="#3A6EA5" Offset="0.5"/>
                                    <GradientStop Color="#0A246A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="REGRA DE TRÊS"
                                       Foreground="#FFFFFF" FontSize="13" FontWeight="Bold"
                                       Padding="8,5"/>
                        </Border>
                    </Border>
                </Border>

                <!-- Proporcionalidade -->
                <Border BorderThickness="2,2,1,1" BorderBrush="#808080" Margin="0,0,0,10"
                        SnapsToDevicePixels="True">
                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF" Background="#D4D0C8"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="PROPORCIONALIDADE" Style="{StaticResource ToolLabelStyle}"
                                       FontWeight="Bold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton x:Name="RbDireta"  Content="Direta  (A↑ → B↑)"
                                             Style="{StaticResource ToolRadioStyle}" IsChecked="True"/>
                                <RadioButton x:Name="RbInversa" Content="Inversa (A↑ → B↓)"
                                             Style="{StaticResource ToolRadioStyle}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="A"
                                           Style="{StaticResource ToolLabelStyle}" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="B"
                                           Style="{StaticResource ToolLabelStyle}" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                                <TextBox x:Name="TbA" Grid.Row="1" Grid.Column="0"
                                         Style="{StaticResource ToolInputStyle}" Height="38" TextAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="→"
                                           Foreground="#404040" FontSize="20"
                                           VerticalAlignment="Center" Margin="8,0"/>
                                <TextBox x:Name="TbB" Grid.Row="1" Grid.Column="2"
                                         Style="{StaticResource ToolInputStyle}" Height="38" TextAlignment="Center"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="C"
                                           Style="{StaticResource ToolLabelStyle}" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="X  (incógnita)"
                                           Style="{StaticResource ToolLabelStyle}" HorizontalAlignment="Center"
                                           FontWeight="Bold"/>
                                <TextBox x:Name="TbC" Grid.Row="4" Grid.Column="0"
                                         Style="{StaticResource ToolInputStyle}" Height="38" TextAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="→"
                                           Foreground="#404040" FontSize="20"
                                           VerticalAlignment="Center" Margin="8,0"/>

                                <!-- Resultado X (sunken display) -->
                                <Border Grid.Row="4" Grid.Column="2"
                                        BorderThickness="2,2,1,1" BorderBrush="#808080"
                                        SnapsToDevicePixels="True">
                                    <Border BorderThickness="1,1,2,2" BorderBrush="#FFFFFF"
                                            Background="#FFFFFF">
                                        <TextBlock x:Name="TbX"
                                                   Foreground="#000080"
                                                   FontFamily="Courier New" FontSize="17" FontWeight="Bold"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Text="?"/>
                                    </Border>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Botão Calcular -->
                <Button Content="Calcular X" Style="{StaticResource ToolButtonStyle}"
                        HorizontalAlignment="Stretch" Height="40" Click="Calcular_Click"/>

            </StackPanel>
        </Border>
    </Border>
</Window>
